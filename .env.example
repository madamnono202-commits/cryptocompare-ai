REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────────────
# AI Content Engine
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=""
NEWSAPI_KEY=""
HUGGINGFACE_API_KEY=""

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
