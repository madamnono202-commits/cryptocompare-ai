# ──────────────────────────────────────────────
# Database (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/cryptocompare_ai"

# ──────────────────────────────────────────────
# Upstash Redis
# ──────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=""
