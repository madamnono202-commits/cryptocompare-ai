generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Core exchange model (business logic TBD)
// ──────────────────────────────────────────────
model Exchange {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  url       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exchanges")
}

// ──────────────────────────────────────────────
// Blog post model (business logic TBD)
// ──────────────────────────────────────────────
model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("posts")
}
